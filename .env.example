# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# MySQL
MYSQL_ROOT_PASSWORD=emailapi
MYSQL_DATABASE=emailapi
# Credentials are overridden by MYSQL_ROOT_PASSWORD and MYSQL_DATABASE above
DATABASE_URL=mysql://root@email-mysql:3306/emailapi

# Redis
REDIS_URL=redis://email-redis:6379

# SMTP (Postfix)
SMTP_HOST=email-postfix
SMTP_PORT=25
# Set to true for direct TLS connections to external SMTP servers
SMTP_TLS=false
POSTFIX_CONFIG_DIR=./config/postfix

# SpamAssassin
SPAMD_HOST=email-spamassassin
SPAMD_PORT=783
SPAM_SCORE_THRESHOLD=5.0

# API
API_URL=http://localhost:3000
# IMPORTANT: Change this to a strong random value in production
MASTER_API_KEY=change-me-in-production

# Internal API secret (min 16 chars) — used by Postfix log watcher to call internal endpoints
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=change-me-internal-secret

# CORS — comma-separated list of allowed origins, or * to allow all
CORS_ORIGINS=*

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100
RATE_LIMIT_SEND_MAX=30

# Admin UI
# Option 1: Plain password (deprecated, logs a warning)
ADMIN_PASSWORD=change-me-admin
# Option 2: bcrypt hash (preferred) — generate with: node -e "require('bcrypt').hash('your-password', 12).then(console.log)"
# ADMIN_PASSWORD_HASH=$2b$12$...
# Optional: false, true, or auto. Defaults to auto in production and false elsewhere.
# COOKIE_SECURE=auto
SESSION_SECRET=change-me-32-char-secret-minimum
