<%- include('../layouts/main', { title: 'Domains', currentPath, flash }) %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-2xl font-bold text-gray-900">Domains</h2>
  <button type="button" data-toggle="add-domain-form" class="bg-gray-900 text-white px-4 py-2 rounded-md text-sm hover:bg-gray-800">Add Domain</button>
</div>

<div id="add-domain-form" class="hidden mb-6 bg-white rounded-lg shadow p-6">
  <form method="POST" action="/admin/domains" class="flex items-end gap-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="flex-1">
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Domain Name</label>
      <input type="text" id="name" name="name" required placeholder="example.com"
        class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
    </div>
    <button type="submit" class="bg-gray-900 text-white px-4 py-2 rounded-md text-sm hover:bg-gray-800">Create</button>
  </form>
</div>

<div class="bg-white rounded-lg shadow overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">SPF</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">DKIM</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">DMARC</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if (domains.length === 0) { %>
        <tr><td colspan="5" class="px-6 py-4 text-sm text-gray-500 text-center">No domains yet</td></tr>
      <% } %>
      <% domains.forEach(function(d) { %>
      <tr class="hover:bg-gray-50">
        <td class="px-6 py-4 whitespace-nowrap">
          <a href="/admin/domains/<%= d.id %>" class="text-blue-600 hover:text-blue-800 font-medium"><%= d.name %></a>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <span class="<%= d.spfVerified ? 'text-green-600' : 'text-red-500' %>"><%= d.spfVerified ? 'Verified' : 'Not verified' %></span>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <span class="<%= d.dkimVerified ? 'text-green-600' : 'text-red-500' %>"><%= d.dkimVerified ? 'Verified' : 'Not verified' %></span>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <span class="<%= d.dmarcVerified ? 'text-green-600' : 'text-red-500' %>"><%= d.dmarcVerified ? 'Verified' : 'Not verified' %></span>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= new Date(d.createdAt).toLocaleDateString() %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('../layouts/footer') %>
