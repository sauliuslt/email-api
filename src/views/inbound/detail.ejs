<%- include('../layouts/main', { title: 'Inbound Email Detail', currentPath, flash }) %>

<div class="mb-6">
  <a href="/admin/inbound" class="text-sm text-gray-500 hover:text-gray-700">&larr; Back to Inbound Emails</a>
</div>

<h2 class="text-2xl font-bold text-gray-900 mb-6">Inbound Email Detail</h2>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Metadata</h3>
    <dl class="space-y-3">
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Classification</dt>
        <dd>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
            <% if (email.classification === 'bounce') { %>bg-red-100 text-red-800<% } else if (email.classification === 'complaint') { %>bg-orange-100 text-orange-800<% } else if (email.classification === 'unsubscribe') { %>bg-yellow-100 text-yellow-800<% } else { %>bg-gray-100 text-gray-800<% } %>
          "><%= email.classification %></span>
        </dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Sender</dt>
        <dd class="text-sm text-gray-900"><%= email.sender %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Recipient</dt>
        <dd class="text-sm text-gray-900"><%= email.recipient %></dd>
      </div>
      <% if (email.subject) { %>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Subject</dt>
        <dd class="text-sm text-gray-900"><%= email.subject %></dd>
      </div>
      <% } %>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Matched</dt>
        <dd class="text-sm text-gray-900"><%= email.matched ? 'Yes' : 'No' %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Received</dt>
        <dd class="text-sm text-gray-900"><%= new Date(email.createdAt).toLocaleString() %></dd>
      </div>
    </dl>
  </div>

  <% if (matchedMessage) { %>
  <div class="bg-white rounded-lg shadow p-6">
    <h3 class="text-lg font-medium text-gray-900 mb-4">Matched Original Message</h3>
    <dl class="space-y-3">
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Status</dt>
        <dd>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
            <% if (matchedMessage.status === 'delivered') { %>bg-green-100 text-green-800<% } else if (matchedMessage.status === 'bounced' || matchedMessage.status === 'failed') { %>bg-red-100 text-red-800<% } else { %>bg-gray-100 text-gray-800<% } %>
          "><%= matchedMessage.status %></span>
        </dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">From</dt>
        <dd class="text-sm text-gray-900"><%= matchedMessage.from %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">To</dt>
        <dd class="text-sm text-gray-900"><%= matchedMessage.to %></dd>
      </div>
      <div class="flex justify-between">
        <dt class="text-sm text-gray-500">Subject</dt>
        <dd class="text-sm text-gray-900"><%= matchedMessage.subject %></dd>
      </div>
    </dl>
    <div class="mt-4">
      <a href="/admin/messages/<%= matchedMessage.id %>" class="text-blue-600 hover:text-blue-800 text-sm">View Original Message &rarr;</a>
    </div>
  </div>
  <% } %>
</div>

<% if (email.details && Object.keys(email.details).length > 0) { %>
<div class="bg-white rounded-lg shadow p-6 mb-6">
  <h3 class="text-lg font-medium text-gray-900 mb-4">Details</h3>
  <pre class="text-sm text-gray-700 bg-gray-50 rounded p-4 overflow-x-auto"><%= JSON.stringify(email.details, null, 2) %></pre>
</div>
<% } %>

<% if (email.rawHeaders) { %>
<div class="bg-white rounded-lg shadow p-6">
  <h3 class="text-lg font-medium text-gray-900 mb-4">Raw Headers</h3>
  <pre class="text-sm text-gray-700 bg-gray-50 rounded p-4 overflow-x-auto whitespace-pre-wrap"><%= email.rawHeaders %></pre>
</div>
<% } %>

<%- include('../layouts/footer') %>
