<% if (flash) { %>
  <div class="mb-6 rounded-md p-4 flash-message
    <%= flash.type === 'success' ? 'bg-green-50 text-green-800 border border-green-200' : '' %>
    <%= flash.type === 'error' ? 'bg-red-50 text-red-800 border border-red-200' : '' %>
    <%= flash.type === 'info' ? 'bg-blue-50 text-blue-800 border border-blue-200' : '' %>
  ">
    <p class="text-sm"><%= flash.message %></p>
  </div>
<% } %>
