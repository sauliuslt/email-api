<aside class="w-64 bg-gray-900 text-gray-300 flex flex-col min-h-screen">
  <div class="p-6">
    <h1 class="text-white text-lg font-bold">Digisensus.ai</h1>
    <p class="text-gray-500 text-sm">Email Sending API</p>
  </div>
  <nav class="flex-1 px-4 space-y-1">
    <a href="/admin" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
      Dashboard
    </a>
    <a href="/admin/domains" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/domains' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
      Domains
    </a>
    <a href="/admin/api-keys" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/api-keys' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
      API Keys
    </a>
    <a href="/admin/messages" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/messages' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
      Messages
    </a>
    <a href="/admin/events" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/events' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
      Events
    </a>
    <a href="/admin/suppressions" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/suppressions' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
      Suppressions
    </a>
    <a href="/admin/ip-pools" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/ip-pools' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
      IP Pools
    </a>
    <div class="mt-4 pt-4 border-t border-gray-700">
      <a href="/admin/api-docs" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/api-docs' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
        API Docs
      </a>
      <a href="/admin/whats-new" class="flex items-center px-3 py-2 rounded-md text-sm font-medium <%= currentPath === '/whats-new' ? 'bg-gray-800 text-white' : 'hover:bg-gray-800 hover:text-white' %>">
        What's New
      </a>
    </div>
  </nav>
  <div class="p-4 border-t border-gray-700">
    <form method="POST" action="/admin/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="w-full px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-md text-left">
        Logout
      </button>
    </form>
  </div>
</aside>
