<%- include('../layouts/main', { title: 'IP Pools', currentPath, flash }) %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-2xl font-bold text-gray-900">IP Pools</h2>
  <button type="button" data-toggle="add-pool-form" class="bg-gray-900 text-white px-4 py-2 rounded-md text-sm hover:bg-gray-800">Create Pool</button>
</div>

<div id="add-pool-form" class="hidden mb-6 bg-white rounded-lg shadow p-6">
  <form method="POST" action="/admin/ip-pools" class="flex items-end gap-4">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="flex-1">
      <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Pool Name</label>
      <input type="text" id="name" name="name" required placeholder="production-pool"
        class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-gray-900">
    </div>
    <button type="submit" class="bg-gray-900 text-white px-4 py-2 rounded-md text-sm hover:bg-gray-800">Create</button>
  </form>
</div>

<div class="bg-white rounded-lg shadow overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Default</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% if (pools.length === 0) { %>
        <tr><td colspan="4" class="px-6 py-4 text-sm text-gray-500 text-center">No IP pools yet</td></tr>
      <% } %>
      <% pools.forEach(function(p) { %>
      <tr class="hover:bg-gray-50">
        <td class="px-6 py-4 whitespace-nowrap">
          <a href="/admin/ip-pools/<%= p.id %>" class="text-blue-600 hover:text-blue-800 font-medium"><%= p.name %></a>
        </td>
        <td class="px-6 py-4 whitespace-nowrap">
          <% if (p.isDefault) { %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Default</span>
          <% } %>
        </td>
        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= new Date(p.createdAt).toLocaleDateString() %></td>
        <td class="px-6 py-4 whitespace-nowrap text-sm">
          <form method="POST" action="/admin/ip-pools/<%= p.id %>/delete" class="inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" data-confirm="Delete this pool and all its IPs?" class="text-red-600 hover:text-red-800">Delete</button>
          </form>
        </td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('../layouts/footer') %>
