{
	"name": "@digisensus/email-api",
	"version": "0.1.0",
	"description": "Digisensus.ai Email Sending API",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"worker": "tsx src/workers/index.ts",
		"worker:dev": "tsx watch src/workers/index.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:seed": "tsx src/db/seed.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@fastify/auth": "^5.0.2",
		"@fastify/cookie": "^11.0.2",
		"@fastify/cors": "^10.0.2",
		"@fastify/csrf-protection": "^7.1.0",
		"@fastify/formbody": "^8.0.2",
		"@fastify/helmet": "^13.0.2",
		"@fastify/rate-limit": "^10.3.0",
		"@fastify/session": "^11.1.1",
		"@fastify/static": "^9.0.0",
		"@fastify/view": "^11.1.1",
		"bcrypt": "^6.0.0",
		"bullmq": "^5.34.8",
		"dotenv": "^16.4.7",
		"drizzle-orm": "^0.38.4",
		"ejs": "^5.0.1",
		"fastify": "^5.2.1",
		"mailparser": "^3.9.4",
		"mysql2": "^3.11.0",
		"nodemailer": "^6.9.16",
		"zod": "^3.24.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/bcrypt": "^6.0.0",
		"@types/ejs": "^3.1.5",
		"@types/mailparser": "^3.4.6",
		"@types/node": "^22.12.0",
		"@types/nodemailer": "^6.4.17",
		"drizzle-kit": "^0.30.4",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"vitest": "^3.0.5"
	}
}
